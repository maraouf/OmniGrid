#!/usr/bin/env bash
# OmniGrid pre-commit shim — calls scripts/lint.py against staged files.
# This file is CHECKED IN at .githooks/pre-commit and activated per-clone
# by `python scripts/install_precommit.py` (which sets core.hooksPath to
# .githooks). Edit here + commit to update the hook on every machine;
# re-run the installer once per fresh clone to activate. Skip the hook
# for ONE commit via `git commit --no-verify`.
set -eu

repo_root="$(git rev-parse --show-toplevel 2>/dev/null || true)"
if [ -z "$repo_root" ]; then
  echo "[pre-commit] not in a git repo — skipping lint" >&2
  exit 0
fi

lint="$repo_root/scripts/lint.py"
if [ ! -f "$lint" ]; then
  # Hook active but the lint script is gone — don't block commits
  # silently. Inform + pass.
  echo "[pre-commit] $lint not found — skipping" >&2
  exit 0
fi

# Resolve a python interpreter — prefer `python` (Windows) then python3.
if command -v python >/dev/null 2>&1; then
  py="python"
elif command -v python3 >/dev/null 2>&1; then
  py="python3"
else
  echo "[pre-commit] neither python nor python3 on PATH — skipping lint" >&2
  exit 0
fi

# Capture the staged text-file set BEFORE normalising so we can re-stage
# the CRLF-fixed bytes below. NUL-delimited for path-with-space safety.
# diff-filter ACMR = Added / Copied / Modified / Renamed (skip Deletes).
staged="$(git diff --cached --name-only --diff-filter=ACMR -z 2>/dev/null || true)"

# --fix-crlf auto-normalises staged files to CRLF FIRST (the harness's
# Edit/Write tools silently re-save edited files as LF on every edit, so
# without this the commit would fail the lone-LF rule on every touched
# file). --severity warn then blocks the commit on any remaining WARNING
# or ERROR finding (info-level prints but doesn't block). The CRLF rule
# passes because the fix already ran. set +e so a non-zero lint exit is
# captured rather than aborting this shim before we re-stage.
set +e
"$py" "$lint" --staged --fix-crlf --severity warn
rc=$?
set -e

# Re-stage the normalised bytes so the CRLF fix lands in THIS commit
# instead of being left as an unstaged working-tree change that re-fails
# the next commit. Caveat: a partially-staged file (git add -p) gets its
# FULL working-tree version re-staged here — acceptable for this
# single-operator repo; use --no-verify if you need a partial stage to
# survive verbatim. Full audit on demand: python scripts/lint.py --all
if [ -n "$staged" ]; then
  printf '%s' "$staged" | xargs -0 git add -- 2>/dev/null || true
fi

exit "$rc"
