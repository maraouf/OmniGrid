# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/

# Runtime data (SQLite DB lives here)
data/
*.db
*.db-journal

# PyCharm
.idea/

# OS
.DS_Store
Thumbs.db

tmp/

# Agent-internal memory should NEVER be served as static content. The
# project-root `.claude/` directory is fine, but if an agent ever writes
# its memory to a nested `.claude/` (e.g. `static/img/icons/.claude/`,
# from a relative-path slip), git ignores it so it can't slip into a
# deploy. See #252 for the incident this guards against.

.claude/worktrees/


# Node — package.json and package-lock.json are committed. node_modules/
# is ALSO committed + shipped (the server serves Alpine / SweetAlert2
# directly from /node_modules/…/dist/ via a FastAPI StaticFiles mount).
# Only the npm-metadata lockfile that lives INSIDE node_modules is noise.
.package-lock.json

# node_modules/.bin/ holds npm's CLI launcher shims. The extensionless
# ones are Unix SYMLINKS (e.g. eslint -> ../eslint/bin/eslint.js) which
# git cannot index on a Windows / WSL `/mnt` (DrvFs) checkout — `git add`
# fails with "open(...): Function not implemented / unable to index
# file". They're dev-tooling launchers only: the server serves the
# package dist files as static and never runs .bin, and `npm run lint`
# resolves the tool from node_modules/<pkg> directly. So they don't
# belong in the committed tree — ignore the whole dir (run
# `git rm -r --cached node_modules/.bin` once to untrack the existing
# entries). The `**/.bin/` form also covers NESTED .bin dirs
# (e.g. node_modules/global-prefix/node_modules/.bin) which carry the
# same launcher shims / symlinks.
node_modules/.bin/
node_modules/**/.bin/

