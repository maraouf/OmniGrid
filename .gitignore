# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/

# Runtime data (SQLite DB lives here)
data/
*.db
*.db-journal

# PyCharm
.idea/

# OS
.DS_Store
Thumbs.db

tmp/

# Agent-internal memory should NEVER be served as static content. The
# project-root `.claude/` directory is fine, but if an agent ever writes
# its memory to a nested `.claude/` (e.g. `static/img/icons/.claude/`,
# from a relative-path slip), git ignores it so it can't slip into a
# deploy. See #252 for the incident this guards against.
**/static/**/.claude/
**/static/**/agent-memory/

# Node — package.json and package-lock.json are committed. node_modules/
# is ALSO committed + shipped (the server serves Alpine / SweetAlert2
# directly from /node_modules/…/dist/ via a FastAPI StaticFiles mount).
# Only the npm-metadata lockfile that lives INSIDE node_modules is noise.
.package-lock.json

